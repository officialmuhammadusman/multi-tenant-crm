{
  "name": "crm-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @crm/db generate",
    "db:migrate:dev": "pnpm --filter @crm/db migrate:dev",
    "db:migrate:deploy": "pnpm --filter @crm/db migrate:deploy",
    "db:seed": "pnpm --filter @crm/db seed",
    "db:studio": "pnpm --filter @crm/db studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "prettier": "^3.4.2",
    "@types/node": "^22.10.5"
  }
}
