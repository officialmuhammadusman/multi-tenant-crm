{
    "compilerOptions":  {
                            "target":  "ES2022",
                            "module":  "commonjs",
                            "lib":  [
                                        "ES2022"
                                    ],
                            "strict":  true,
                            "esModuleInterop":  true,
                            "skipLibCheck":  true,
                            "resolveJsonModule":  true,
                            "rootDir":  "./src",
                            "outDir":  "./dist",
                            "declaration":  true,
                            "sourceMap":  true,
                            "forceConsistentCasingInFileNames": true,
                            "moduleResolution": "node",
                            "ignoreDeprecations": "6.0"
                        },
    "include":  [
                    "src/**/*"
                ],
    "exclude":  [
                    "node_modules",
                    "dist",
                    "prisma"
                ]
}