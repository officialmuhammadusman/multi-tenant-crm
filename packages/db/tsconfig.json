{
    "compilerOptions":  {
                            "target":  "ES2022",
                            "module":  "commonjs",
                            "lib":  [
                                        "ES2022"
                                    ],
                            "strict":  true,
                            "esModuleInterop":  true,
                            "skipLibCheck":  true,
                            "resolveJsonModule":  true,
                            "rootDir":  "./src",
                            "outDir":  "./dist",
                            "declaration":  true,
                            "sourceMap":  true
                        },
    "include":  [
                    "src/**/*"
                ],
    "exclude":  [
                    "node_modules",
                    "dist"
                ]
}
